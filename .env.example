# ============================================================================
# SIBT-DISHUB — Contoh variabel lingkungan.
# Salin ke .env (lokal) atau set di dashboard Vercel (production).
# JANGAN commit file .env yang berisi nilai asli.
# ============================================================================

# --- Database (WAJIB) -------------------------------------------------------
# PostgreSQL. Untuk Neon/Supabase gunakan connection string berpooling.
# Contoh Neon: postgresql://user:pass@ep-xxx.pooler.region.aws.neon.tech/db?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/sibt_dishub?schema=public"

# Opsional: koneksi langsung (non-pool) untuk `prisma migrate` di CI/Neon.
# DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/db?sslmode=require"

# --- Auth.js (WAJIB) --------------------------------------------------------
# Secret untuk menandatangani JWT sesi. Generate dengan: openssl rand -base64 32
AUTH_SECRET="ganti-dengan-secret-acak-minimal-32-karakter"
# Vercel meng-set host otomatis; untuk deployment lain set true bila perlu.
# AUTH_TRUST_HOST="true"

# --- Aplikasi ---------------------------------------------------------------
# Zona waktu kantor — semua batas "hari ini" dihitung pada zona ini.
# Pilihan: Asia/Jakarta (WIB) | Asia/Makassar (WITA) | Asia/Jayapura (WIT)
APP_TIMEZONE="Asia/Jakarta"
# URL publik aplikasi — dipakai menyusun tautan QR kios. Set ke domain asli.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Vercel Blob (WAJIB bila fitur foto tamu dipakai) -----------------------
# Token dari Vercel Storage > Blob. Tanpa ini, upload foto ditolak dengan
# pesan jelas (foto bersifat opsional, sistem tetap jalan tanpa foto).
BLOB_READ_WRITE_TOKEN=""

# --- Rate limiting (opsional, DISARANKAN untuk production) ------------------
# Upstash Redis (REST). Tanpa ini, limiter fallback ke in-memory yang TIDAK
# aman untuk deployment multi-instance/serverless (lihat docs/01 §4.6).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
